# Primary option-chain provider: auto | yahoo | marketdata | tradier
OPTIONS_PROVIDER=auto

# Optional option data sources. Yahoo fallback works without a key.
MARKETDATA_TOKEN=
TRADIER_TOKEN=
TRADIER_BASE_URL=https://sandbox.tradier.com
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_OPTIONS_FEED=indicative

# Alert delivery. Never commit real values.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Free official catalyst sources.
# SEC asks automated clients to identify the application and a contact address.
SEC_USER_AGENT=GHAZI Options Radar your-email@example.com
# Optional free key. Without it openFDA allows 1,000 calls/day per IP.
OPENFDA_API_KEY=

# Optional daily email through Gmail SMTP. Use an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=

# Scanner defaults
RISK_FREE_RATE=0.043
MIN_DTE=3
MAX_DTE=45
MIN_OPTION_VOLUME=50
MIN_OPEN_INTEREST=100
MAX_SPREAD_PCT=0.20
MIN_ABS_DELTA=0.30
MAX_ABS_DELTA=0.60
MIN_SCORE=65
ALERT_SCORE=76
ALERT_VOL_OI=2.0
MAX_WORKERS=4
DATABASE_PATH=data/options_radar.sqlite3
