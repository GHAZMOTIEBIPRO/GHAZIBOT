# Primary option-chain provider: auto | yahoo | marketdata | tradier
OPTIONS_PROVIDER=auto

# Optional option data sources. Auto merges every configured provider and keeps Yahoo as fallback.
MARKETDATA_TOKEN=
TRADIER_TOKEN=
TRADIER_BASE_URL=https://sandbox.tradier.com
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_OPTIONS_FEED=indicative
ALPACA_STOCK_FEED=iex

# Optional free-account stock bar sources. No secret is ever published.
TWELVE_DATA_API_KEY=
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# Daily scans default to Yahoo first to protect small free quotas across a large universe.
# Intraday outcome tracking prefers official account APIs when configured.
DAILY_PRICE_PROVIDER_ORDER=yahoo,tradier,alpaca,twelve_data,polygon,alpha_vantage
INTRADAY_PRICE_PROVIDER_ORDER=tradier,alpaca,twelve_data,polygon,yahoo,alpha_vantage

# Free official catalyst sources.
# SEC asks automated clients to identify the application and a contact address.
SEC_USER_AGENT=GHAZI Options Radar your-email@example.com
# Optional free key. Without it openFDA works within its public unauthenticated limit.
OPENFDA_API_KEY=

# Scanner defaults
RISK_FREE_RATE=0.043
FREE_SWING_MODE=true
MIN_DTE=14
MAX_DTE=60
MIN_OPTION_VOLUME=50
MIN_OPEN_INTEREST=100
MAX_SPREAD_PCT=0.20
MIN_ABS_DELTA=0.30
MAX_ABS_DELTA=0.60
MIN_OPTION_PRICE=0.25
MAX_OPTION_PRICE=30
MIN_DATA_QUALITY=0.50
MAX_LAST_TRADE_AGE_MINUTES=10080
MIN_SCORE=65
ALERT_SCORE=76
ALERT_VOL_OI=2.0
MAX_WORKERS=4
MAX_UNIVERSE_SIZE=120
CALIBRATION_MINIMUM_SAMPLE=100
MODEL_VERSION=2026.07-phase3

# Persistent evidence files used by GitHub Actions.
DATABASE_PATH=data/live/alert_state.json
SIGNAL_JOURNAL_PATH=data/live/signals.jsonl
OUTCOME_PATH=data/live/outcomes.json
CALIBRATION_PATH=data/live/calibration.json
